# Real-time Messaging & Calling System Configuration

# ================================================================
# EDIT THESE FIRST (required)
# ================================================================
# 1) Copy this file to .env.local
# 2) Replace the 4 values below with your own project values
#
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...
# VITE_SOCKET_URL=...
# SOCKET_PORT=...

# ════════════════════════════════════════════════════════════════════
# Socket.io Server Configuration
# ════════════════════════════════════════════════════════════════════

# Socket.io Server URL (for frontend connection)
# Local Development
VITE_SOCKET_URL=http://localhost:3001

# Socket server port (used by server.js)
SOCKET_PORT=3001

# Production (replace with your server URL)
# VITE_SOCKET_URL=https://api.taskflow.app:3001

# ════════════════════════════════════════════════════════════════════
# Supabase Configuration (Database)
# ════════════════════════════════════════════════════════════════════

VITE_SUPABASE_URL=https://vtuwiqnpexbhexlblhyh.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_VFKCmSxy5vtqw7eHHqrJXQ_ITwVfBoU



# ════════════════════════════════════════════════════════════════════
# WebRTC Configuration
# ════════════════════════════════════════════════════════════════════

# STUN Servers (for NAT traversal)
# Default: Google's STUN server (free, reliable)
# Can add multiple servers for redundancy
VITE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN Servers (for symmetric NAT - optional but recommended for production)
# Format: turn:server_address:port?transport=protocol
# Example: turn:turnserver.example.com:3478?transport=tcp
VITE_TURN_SERVER=turn:openrelay.metered.ca:80
VITE_TURN_USERNAME=openrelayproject
VITE_TURN_PASSWORD=openrelayproject

# ════════════════════════════════════════════════════════════════════
# Media Configuration
# ════════════════════════════════════════════════════════════════════

# Default camera resolution for video calls
VITE_VIDEO_WIDTH=1280
VITE_VIDEO_HEIGHT=720

# Audio settings
VITE_AUDIO_ECHO_CANCELLATION=true
VITE_AUDIO_NOISE_SUPPRESSION=true
VITE_AUDIO_AUTO_GAIN_CONTROL=true

# ════════════════════════════════════════════════════════════════════
# Application Configuration
# ════════════════════════════════════════════════════════════════════

# Enable detailed logging
VITE_DEBUG_MODE=false

# Message retention (in days)
VITE_MESSAGE_RETENTION_DAYS=90

# Max file upload size (in MB)
VITE_MAX_FILE_SIZE_MB=50

# Call timeout in seconds (auto-reject if no answer)
VITE_CALL_RING_TIMEOUT=30

# ════════════════════════════════════════════════════════════════════
# Feature Flags
# ════════════════════════════════════════════════════════════════════

# Enable group calling
VITE_FEATURE_GROUP_CALLS=true

# Enable message reactions
VITE_FEATURE_MESSAGE_REACTIONS=true

# Enable message search
VITE_FEATURE_MESSAGE_SEARCH=true

# Enable voice messages
VITE_FEATURE_VOICE_MESSAGES=false

# Enable call recording (requires additional setup)
VITE_FEATURE_CALL_RECORDING=false

# ════════════════════════════════════════════════════════════════════
# IMPORTANT SETUP INSTRUCTIONS
# ════════════════════════════════════════════════════════════════════

###############################################
# 1. Socket.io Server Setup
###############################################

# First, install dependencies:
# npm install express socket.io cors dotenv @supabase/supabase-js

# Then, start the server:
# npm run dev:server

# The server will listen on port 3001 by default
# Update VITE_SOCKET_URL if running on a different port/machine


###############################################
# 2. Supabase Migrations
###############################################

# Apply the new migration for message status tracking:
# supabase migration up --file supabase/migrations/007_message_status_tracking.sql

# This adds:
# - Message status tracking (sent, delivered, seen)
# - Read receipts with timestamps
# - Call connection details
# - Performance indexes
# - Enhanced RLS policies


###############################################
# 3. WebRTC Configuration
###############################################

# For local development:
# - STUN servers are enough (provided free by Google)
# - No TURN server needed for same-network calls

# For production:
# - Consider setting up a TURN server for better reliability
# - Options: coturn (self-hosted), AWS, Twilio, etc.


###############################################
# 4. Browser Permissions
###############################################

# Users will see permission prompts for:
# - Camera access
# - Microphone access
# - Speaker access

# Handle these with the useMedia hook:
# const { requestMedia, isAudioEnabled, isVideoEnabled } = useMedia();


###############################################
# 5. Running Everything
###############################################

# Development (both frontend + server):
# npm run dev:all

# Frontend only (socket server must be running):
# npm run dev

# Socket server only:
# npm run dev:server

# Production build:
# npm run build

# ════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ════════════════════════════════════════════════════════════════════

###############################################
# Issue: Socket connections failing
# Solution: 
# 1. Ensure socket server is running (npm run dev:server)
# 2. Check VITE_SOCKET_URL matches server address
# 3. Check browser console for CORS errors
# 4. Ensure port 3001 is not blocked by firewall


###############################################
# Issue: No media device access
# Solution:
# 1. Check browser permissions for camera/microphone
# 2. Ensure HTTPS in production (required for media access)
# 3. Check if devices are in use by other applications
# 4. Try different browser (Firefox, Chrome, Safari)


###############################################
# Issue: WebRTC connection fails
# Solution:
# 1. Ensure STUN/TURN servers are configured
# 2. Check network connectivity between peers
# 3. Test with same network first (no TURN needed)
# 4. Check for symmetric NAT (requires TURN server)


###############################################
# Issue: Messages not syncing
# Solution:
# 1. Verify socket server is running
# 2. Check Supabase connection
# 3. Verify migrations are applied
# 4. Check RLS policies in Supabase dashboard
# 5. Look at server logs for errors

